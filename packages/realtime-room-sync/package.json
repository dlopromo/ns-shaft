{
  "name": "realtime-room-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./firebase": {
      "types": "./dist/firebase.d.ts",
      "import": "./dist/firebase.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude tests/firebase.test.ts",
    "test:firebase": "firebase emulators:exec --project demo-realtime-room-sync --only auth,database \"vitest run tests/firebase.test.ts\""
  },
  "peerDependencies": {
    "firebase": ">=10 <13"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.0.0",
    "firebase-tools": "^14.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
